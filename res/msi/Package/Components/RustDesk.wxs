			<Component Guid="537aa2e0-4156-4d13-8886-91600da828d3" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/rustdesk/rustdesk/data/flutter_assets/assets/file.svg" KeyPath="yes" Checksum="yes" />
