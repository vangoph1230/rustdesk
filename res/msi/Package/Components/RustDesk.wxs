			</Component>
			<Component Guid="9cf59769-eeb0-49a6-bdef-e0d172bd292b" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/rustdesk/rustdesk/data/flutter_assets/assets/display.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="e0c63aaf-ffa6-4cb0-887d-6dfce8b48f44" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/rustdesk/rustdesk/data/flutter_assets/assets/dots.svg" KeyPath="yes" Checksum="yes" />
