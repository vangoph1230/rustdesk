				<File Source="E:/rustdesk/rustdesk/flutter_windows.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="89aa8b4d-104e-467a-b2fc-7b7696257373" >
				<File Source="E:/rustdesk/rustdesk/librustdesk.dll" KeyPath="yes" Checksum="yes" />
